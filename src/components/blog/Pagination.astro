---
interface Props {
  page: {
    currentPage: number;
    lastPage: number;
    url: {
      prev: string | undefined;
      next: string | undefined;
    };
  };
  basePath?: string;
}

const { page, basePath = '/blog' } = Astro.props;
const { currentPage, lastPage } = page;
const pages = Array.from({ length: lastPage }, (_, i) => i + 1);

function pageUrl(pageNum: number): string {
  if (pageNum === 1) return `${basePath}/`;
  return `${basePath}/page/${pageNum}/`;
}
---

<nav class="mt-16 mb-8 flex items-center justify-center gap-2 font-nudica text-lg font-black">
  {page.url.prev && (
    <a href={page.url.prev}
       class="text-link hover:text-sasquatch-socks transition-colors h-11 w-11 text-center content-center zen:text-ash zen:dark:text-antropia-white">
      &larr;
    </a>
  )}

  {pages.map((pageNum) =>
    pageNum === currentPage ? (
      <span
        class="dark:text-antropia-white font-bold h-11 w-11 text-center content-center zen:rounded-full zen:border">{pageNum}</span>
    ) : (
      <a href={pageUrl(pageNum)}
         class="text-link transition-colors h-11 w-11 text-center content-center zen:text-ash zen:dark:text-antropia-white">
        {pageNum}
      </a>
    ),
  )}

  {page.url.next && (
    <a href={page.url.next}
       class="text-link hover:text-sasquatch-socks transition-colors h-11 w-11 text-center content-center zen:text-ash zen:dark:text-antropia-white">
      &rarr;
    </a>
  )}
</nav>
