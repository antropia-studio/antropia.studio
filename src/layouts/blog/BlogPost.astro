---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import Head from '../../components/blog/Head.astro';
import Header from '../../components/blog/Header.astro';
import PostMetadata from '../../components/blog/PostMetadata.astro';
import Settings from '../../components/blog/Settings.astro';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import Footer from '../../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'] & {
  headings: MarkdownHeading[];
};

const { title, description, heroImage, keywords, headings } = Astro.props;
---

<html class="dark" lang="en">
<Head
  title={title}
  description={description}
  image={heroImage ?? '/images/social.blog.png'}
  keywords={keywords}
/>
<body class="bg-antropia-white dark:bg-ash text-black dark:text-antropia-white">
<Header honorZenMode />

<main class="center font-nudica flex zen:pb-16">
  <article class="w-full">
    <div class="prose px-6">
      <div class="mb-8 flex flex-col items-center">
        <p
          id="blog-title"
          data-title={title}
          class="font-round8 text-ash mb-0! text-center text-[26vw] whitespace-pre-wrap leading-[80%] font-bold uppercase md:text-9xl xl:text-12xl dark:text-antropia-white w-full px-4 max-w-content zen:text-8xl zen:px-0 zen:text-left zen:mt-10"
        >
          {title.replace(/ /g, '   ')}
        </p>

        <PostMetadata {...Astro.props} />

        <p
          class="mt-10 xl:mt-6 px-10 text-center text-xl font-normal italic text-ash/60 dark:text-white/60 zen:text-left zen:px-0">
          {description}
        </p>

        <div class="h-px bg-hello-summer/20 w-full hidden zen:flex" />

        <div class="hero-image zen:hidden">
          {
            heroImage && (
              <Image
                width={1020}
                height={510}
                src={heroImage}
                alt=""
                style="border-radius: 1rem"
              />
            )
          }
        </div>
      </div>

      <slot />
    </div>
  </article>
</main>

<div class="pb-16 zen:hidden">
  <Footer includeRss includeContactUs />
</div>

<script>
  const blogTitle = document.getElementById('blog-title')!;

  const observer = new MutationObserver(() => {
    const isZen = document.documentElement.dataset.readmode === 'zen';
    const title = blogTitle.dataset.title!;

    if (isZen) {
      blogTitle.innerText = title;
    } else {
      blogTitle.innerText = title.replace(/ /g, '   ');
    }
  });

  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-readmode'],
  });
</script>

<TableOfContents headings={headings} />
<Settings />

</body>
</html>
